    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "env-paths": "^4.0.0",
    "zod": "^3.25.76",
    "typesense": "^3.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
