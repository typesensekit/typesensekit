---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  guide?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "TypesenseKit — Typesense CLI and MCP server",
  description = "Operate Typesense from your terminal or AI agent with one typed CLI and MCP operation registry.",
  path = Astro.url.pathname,
  guide = false,
  schema,
} = Astro.props;
const canonical = new URL(path, Astro.site);
const socialImage = new URL("/images/github-og.png", Astro.site);
const organizationSchema = {
  "@type": "Organization",
  "@id": "https://typesensekit.vercel.app/#organization",
  name: "TypesenseKit",
  url: "https://typesensekit.vercel.app/",
  sameAs: [
    "https://github.com/akshitkrnagpal/typesensekit",
    "https://www.npmjs.com/package/@typesensekit/cli",
    "https://www.npmjs.com/package/@typesensekit/mcp",
  ],
};
const websiteSchema = {
  "@type": "WebSite",
  "@id": "https://typesensekit.vercel.app/#website",
  name: "TypesenseKit",
  alternateName: "Typesense CLI and MCP",
  url: "https://typesensekit.vercel.app/",
  description: "Open-source Typesense CLI and MCP server for search operations and AI agents.",
  publisher: { "@id": "https://typesensekit.vercel.app/#organization" },
};
const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const schemaGraph = [
  ...(path === "/" ? [organizationSchema, websiteSchema] : pageSchemas.length > 0 ? [organizationSchema] : []),
  ...pageSchemas,
];
const serializedSchema = schemaGraph.length > 0 ? JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph }).replaceAll("<", "\\u003c") : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#071013" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="DEZBH2dmhycBuxMl4CAnDAZw_rSTNtQNiQljZrmy2vg" />
    <link rel="icon" href="/images/github-og.png" type="image/png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TypesenseKit" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {serializedSchema && <script type="application/ld+json" set:html={serializedSchema} is:inline />}
    <title>{title}</title>
  </head>
  <body class:list={{ "guide-page": guide }}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <nav class="nav-shell" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="TypesenseKit home">
          <span class="brand-mark" aria-hidden="true">⌕</span>
          <span>Typesense<span>Kit</span></span>
        </a>
        <div class="nav-links">
          <a href={guide ? "/#product" : "#product"}>Product</a>
          <a href="/typesense-cli/">CLI</a>
          <a href="/typesense-mcp/">MCP</a>
          <a href="/guides/clients/">Guides</a>
          <a class="nav-github" href="https://github.com/akshitkrnagpal/typesensekit">GitHub <span aria-hidden="true">↗</span></a>
        </div>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-shell">
        <div>
          <a class="brand footer-brand" href="/">
            <span class="brand-mark" aria-hidden="true">⌕</span>
            <span>Typesense<span>Kit</span></span>
          </a>
          <p>One toolkit for Typesense operators and AI agents.</p>
        </div>
        <div class="footer-links" aria-label="Project links">
          <a href="https://www.npmjs.com/package/@typesensekit/cli">CLI on npm</a>
          <a href="https://www.npmjs.com/package/@typesensekit/mcp">MCP on npm</a>
          <a href="/typesense-cli/">Typesense CLI</a>
          <a href="/typesense-mcp/">Typesense MCP</a>
          <a href="https://github.com/akshitkrnagpal/typesensekit/releases">Releases</a>
          <a href="https://github.com/akshitkrnagpal/typesensekit/blob/main/CONTRIBUTING.md">Contributing</a>
          <a href="https://github.com/akshitkrnagpal/typesensekit/blob/main/LICENSE">MIT License</a>
        </div>
      </div>
      <div class="footer-base">
        <span>Built for the Typesense community.</span>
        <span>CLI + MCP · Open source</span>
      </div>
    </footer>
    <div class="sr-only" aria-live="polite" id="copy-status"></div>
    <script>
      const status = document.querySelector<HTMLElement>("#copy-status");
      document.querySelectorAll<HTMLButtonElement>("[data-copy-code]").forEach((button) => {
        button.addEventListener("click", async () => {
          const code = button.closest(".code-block")?.querySelector("code")?.textContent ?? "";
          await navigator.clipboard.writeText(code);
          const label = button.querySelector("span");
          if (label) label.textContent = "Copied";
          if (status) status.textContent = "Code copied to clipboard";
          window.setTimeout(() => {
            if (label) label.textContent = "Copy";
          }, 1800);
        });
      });
    </script>
  </body>
</html>
