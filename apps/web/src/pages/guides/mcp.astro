---
import CopyCode from "../../components/CopyCode.astro";
import GuideLayout from "../../layouts/GuideLayout.astro";

const toc = [
  { href: "#start", label: "Start with stdio" },
  { href: "#read-only", label: "Read-only default" },
  { href: "#full-access", label: "Full access" },
  { href: "#resources", label: "MCP resources" },
  { href: "#http", label: "HTTP and Docker" },
  { href: "#registry", label: "Registry" },
  { href: "#production", label: "Production safety" },
