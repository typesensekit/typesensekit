{
  "name": "typesensekit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=22.11"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm -r --parallel --filter './packages/*' run dev",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "docs:coverage": "pnpm build && node scripts/generate-api-coverage.mjs",
    "docs:check": "node scripts/generate-api-coverage.mjs --check",
    "changeset": "changeset",
    "release": "changeset publish",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm docs:check",
    "pack:dry": "npm pack --dry-run --json ./packages/cli && npm pack --dry-run --json ./packages/mcp",
    "prepublishOnly": "pnpm check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  },
  "description": "CLI and MCP server for the Typesense API.",
  "license": "MIT",
  "author": "Akshit Kr Nagpal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akshitkrnagpal/typesensekit.git"
  },
  "bugs": {
    "url": "https://github.com/akshitkrnagpal/typesensekit/issues"
  },
  "homepage": "https://github.com/akshitkrnagpal/typesensekit#readme"
}
